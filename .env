# Development Environment
VITE_NODE_ENV=development

# Set to 'true' to bypass authentication in development
VITE_DEV_BYPASS_AUTH=true

# Firebase Configuration (placeholder values for development)
VITE_FIREBASE_API_KEY=demo-key-for-development
VITE_FIREBASE_AUTH_DOMAIN=demo-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-project
VITE_FIREBASE_STORAGE_BUCKET=demo-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Google Sheets API (for future use)
VITE_GOOGLE_SHEETS_API_KEY=your_sheets_api_key_here
VITE_GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here